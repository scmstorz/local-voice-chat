OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.6:latest
HOST=127.0.0.1
PORT=8000
SYSTEM_PROMPT=Du bist ein lokaler Voice-Chat-Assistent. Antworte knapp, direkt und in der Sprache des Nutzers.

# Preferred built-in Python path:
WHISPER_MODEL=mlx-community/whisper-large-v3-mlx

# Optional override. If set, the server runs this command for transcription.
# Use {file} as placeholder. The command must print the transcript to stdout.
# Example:
# STT_COMMAND=python -m mlx_whisper.transcribe --path_or_hf_repo mlx-community/whisper-large-v3-mlx {file}
STT_COMMAND=

TTS_VOICE=
TTS_RATE=185
