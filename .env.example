OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.6:latest
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_PREDICT=256
OLLAMA_NUM_CTX=4096
OLLAMA_TEMPERATURE=0.4
OLLAMA_DISABLE_THINKING=1
HOST=127.0.0.1
PORT=8000
SYSTEM_PROMPT=Du bist ein lokaler Voice-Chat-Assistent. Antworte knapp, direkt und in der Sprache des Nutzers. Antworte normalerweise in hoechstens vier Saetzen. Gib nur die finale Antwort aus.

# Fast default for interactive voice chat. Use mlx-community/whisper-large-v3-mlx for higher accuracy.
WHISPER_MODEL=mlx-community/whisper-tiny
STT_PROVIDER=browser
STT_LANGUAGE=de
STT_FP16=1
STT_TEMPERATURE=0
STT_CONDITION_ON_PREVIOUS_TEXT=0
STT_OFFLINE=1
STT_DISABLE_PROGRESS=1

# Optional override. If set, the server runs this command for transcription.
# Use {file} as placeholder. The command must print the transcript to stdout.
# Example:
# STT_COMMAND=python -m mlx_whisper.transcribe --path_or_hf_repo mlx-community/whisper-large-v3-mlx {file}
STT_COMMAND=

TTS_VOICE=
TTS_RATE=185
